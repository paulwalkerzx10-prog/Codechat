{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the Relay app, identified by a unique 6-character code.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "code": { "type": "string" },
        "displayName": { "type": "string" },
        "createdAt": { "type": "timestamp" },
        "accentColor": { "type": "string" },
        "patternEnabled": { "type": "boolean" },
        "patternStyle": { "type": "string" }
      },
      "required": ["uid", "code", "displayName", "createdAt"]
    },
    "Contact": {
      "title": "Contact",
      "description": "A contact added by a user.",
      "type": "object",
      "properties": {
        "code": { "type": "string" },
        "displayName": { "type": "string" },
        "lastMessageAt": { "type": "timestamp" },
        "lastReadAt": { "type": "timestamp" },
        "createdAt": { "type": "timestamp" }
      },
      "required": ["code", "displayName", "createdAt"]
    },
    "Conversation": {
      "title": "Conversation",
      "description": "A chat conversation between two users.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "uids": { "type": "list" },
        "codes": { "type": "list" }
      },
      "required": ["id", "uids", "codes"]
    },
    "Message": {
      "title": "Message",
      "description": "A single message in a conversation.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "senderCode": { "type": "string" },
        "text": { "type": "string" },
        "timestamp": { "type": "timestamp" },
        "attachment": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "type": { "type": "string" },
            "size": { "type": "number" },
            "url": { "type": "string" }
          },
          "required": ["name", "type", "size", "url"]
        }
      },
      "required": ["id", "senderCode", "text", "timestamp"]
    }
  },
  "firestore": {
    "/users/{code}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles indexed by their unique 6-character code."
    },
    "/users/{code}/contacts/{contactCode}": {
      "schema": { "$ref": "#/entities/Contact" },
      "description": "A user's contact list."
    },
    "/conversations/{conversationId}": {
      "schema": { "$ref": "#/entities/Conversation" },
      "description": "Conversations storing participant UIDs for security."
    },
    "/conversations/{conversationId}/messages/{messageId}": {
      "schema": { "$ref": "#/entities/Message" },
      "description": "Messages inside a conversation."
    }
  }
}
